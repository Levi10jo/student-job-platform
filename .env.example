# StudyWork – Umgebungsvariablen (Vorlage)
# Kopiere diese Datei zu ".env" und passe die Werte an.
# Die echte .env-Datei wird NICHT eingecheckt (siehe .gitignore).

# Port, auf dem der Express-Server (inkl. statischem Frontend) läuft
PORT=3000

# MySQL-Verbindungsdaten
DB_HOST=localhost
DB_PORT=3306
DB_USER=studywork
DB_PASSWORD=changeme
DB_NAME=studywork

# Laufzeitumgebung: development | production
# Steuert u. a. ob Debug-Logs ausgegeben werden.
NODE_ENV=development
